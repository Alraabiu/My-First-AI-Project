# Azure Cognitive Services Speech resource
# Create one at https://portal.azure.com -> "Speech service"
# Free tier (F0) is enough for testing.
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here
# e.g. eastus, westeurope, southafricanorth — pick the region you created the resource in

# Comma-separated list of origins allowed to call this API
# e.g. https://your-frontend.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Port the Express server listens on
PORT=5000

# How long generated audio files are kept on disk, in minutes
AUDIO_TTL_MINUTES=60

# Public base URL of this backend once deployed (used to build audio URLs)
# e.g. https://api.yourdomain.com  (leave blank to auto-detect from request host)
PUBLIC_BASE_URL=
